POSTGRES_USER=frontdock
POSTGRES_PASSWORD=frontdock_dev_password
POSTGRES_DB=frontdock

DATABASE_URL=postgres://frontdock:frontdock_dev_password@postgres:5432/frontdock?sslmode=disable

RABBITMQ_DEFAULT_USER=frontdock
RABBITMQ_DEFAULT_PASS=frontdock_dev_password
RABBITMQ_URL=amqp://frontdock:frontdock_dev_password@rabbitmq:5672/

MINIO_ROOT_USER=frontdock
MINIO_ROOT_PASSWORD=frontdock_dev_password
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=frontdock
MINIO_SECRET_KEY=frontdock_dev_password
MINIO_USE_SSL=false
MINIO_BUCKET_UPLOADS=frontdock-uploads
MINIO_BUCKET_SITES=frontdock-sites

SMTP_HOST=mailpit
SMTP_PORT=1025
MAIL_FROM=no-reply@frontdock.dev

API_HTTP_ADDR=:8080
API_GRPC_ADDR=:9090
EDGE_HTTP_ADDR=:8081
CONTROL_GRPC_TARGET=api:9090

SITE_DOMAIN=frontdock.dev

PUBLIC_API_URL=http://localhost:8080

JWT_SECRET=CHANGE_ME_openssl_rand_base64_48
JWT_TTL_MINUTES=60

MAX_UPLOAD_BYTES=52428800
MAX_UNPACKED_BYTES=209715200
MAX_FILES_PER_DEPLOY=2000

LOG_LEVEL=info
